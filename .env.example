# LLM (LiteLLM model string). Local example: ollama_chat/qwen2.5:7b
# Production example: claude-3-5-haiku-latest
KOTOLOG_MODEL=ollama_chat/qwen2.5:7b

# API key for hosted models (unused for local Ollama)
KOTOLOG_API_KEY=

# Ollama API base (used only for local models)
KOTOLOG_OLLAMA_BASE=http://localhost:11434

# DB URL. Local SQLite file by default.
# Production (Turso) example: libsql://your-db.turso.io
KOTOLOG_DB_URL=kotolog.db

# Child alias used when none is specified (NFR-4: no real names)
KOTOLOG_DEFAULT_CHILD=baby
