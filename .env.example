# LLM (LiteLLM model string). Local example: ollama_chat/qwen2.5:7b
# Production example: claude-3-5-haiku-latest
KOTOLOG_MODEL=ollama_chat/qwen2.5:7b

# API key for hosted models (unused for local Ollama)
KOTOLOG_API_KEY=

# Ollama API base (used only for local models)
KOTOLOG_OLLAMA_BASE=http://localhost:11434

# DB URL. Local SQLite file by default.
# Production (Turso) example: libsql://your-db.turso.io
KOTOLOG_DB_URL=kotolog.db

# Child alias used when none is specified (NFR-4: no real names)
KOTOLOG_DEFAULT_CHILD=baby


# LINE Messaging API (required for P2 webhook)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Turso (required for P3 production DB)
# KOTOLOG_DB_URL=libsql://koto-log-xxxx.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=

# トークン使用量の計測（P7 / ADR-0002）。1/true/yes で operation 別の 1行 JSON をログ出力。
# 未設定なら無計測（本文・引数値はログに含めない）。
KOTOLOG_USAGE_LOG=

# トークン使用量の DB 永続化（Issue #68 / ADR-0002）。1/true/yes で usage_log テーブルへ
# 保存する（KOTOLOG_USAGE_LOG と併用可、両方ONなら両方に出力）。月次コストは
# `uv run python -m kotolog.usage_report --month YYYY-MM` で確認する。
KOTOLOG_USAGE_DB=
